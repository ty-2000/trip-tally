{
  "name": "trip-tally-backend",
  "version": "1.0.0",
  "description": "Trip Tally serverless backend",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/functions/*.ts --bundle --platform=node --target=node20 --outdir=dist/functions --external:pg-native",
    "build:watch": "tsc --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "dev": "ts-node --transpile-only src/local-server.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "pg": "^8.12.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.143",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^9.0.8",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "esbuild": "^0.21.5",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.ts", "**/*.test.ts"]
  }
}
