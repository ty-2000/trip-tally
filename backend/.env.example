# ── Backend selection ─────────────────────────────────────────────────────────
# DB_BACKEND=postgres   (default) → Aurora / local Postgres
# DB_BACKEND=dynamodb             → DynamoDB / local DynamoDB
DB_BACKEND=postgres

# ── PostgreSQL (DB_BACKEND=postgres) ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=triptally
DB_USER=triptally_admin
DB_PASSWORD=localpassword
DB_SSL=false

# ── DynamoDB (DB_BACKEND=dynamodb) ────────────────────────────────────────────
DYNAMODB_TABLE=trip-tally
# Local only — remove this line when deploying to AWS (uses IAM role instead)
DYNAMODB_ENDPOINT=http://localhost:8000

# ── Shared ────────────────────────────────────────────────────────────────────
RECEIPTS_BUCKET=trip-tally-receipts-local
FRONTEND_URL=http://localhost:3000
AWS_REGION=us-east-1
